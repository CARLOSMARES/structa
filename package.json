{
  "name": "structa",
  "version": "0.8.3",
  "description": "Structa Framework - TypeScript-like API framework",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "prepare": "npx husky install || true",
    "build": "npm run build --workspaces --if-present",
    "publish": "npm run publish --workspaces --if-present",
    "publish:all": "npm run build && npm run publish --workspaces --if-present"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/CARLOSMARES/structa.git"
  },
  "keywords": ["structa", "framework", "api", "rust", "compiler"],
  "author": "Carlos Mares",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/CARLOSMARES/structa/issues"
  },
  "homepage": "https://github.com/CARLOSMARES/structa#readme",
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "husky": "^9.1.7"
  }
}
