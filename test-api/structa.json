{
    "name": "test-api",
    "template": "latest",
    "version": "0.1.0",
    "compiler": {
        "target": "es2022",
        "module": "commonjs",
        "strict": true,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "declaration": true,
        "sourceMap": true,
        "esModuleInterop": true,
        "skipLibCheck": true
    },
    "server": {
        "port": 3000,
        "host": "0.0.0.0",
        "cors": {
            "origin": "*",
            "credentials": true
        },
        "prefix": "/api"
    },
    "database": {
        "type": "sqlite",
        "database": "./data.db"
    },
    "swagger": {
        "title": "test-api API",
        "description": "API Documentation",
        "version": "1.0.0",
        "path": "/docs"
    }
}